<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="piper_x_estop_world">

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <sor>1.4</sor>
        </solver>
      </ode>
    </physics>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode><mu>100</mu><mu2>50</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <!--
      Vertical wall panel on which the e-stop is mounted.
      Box 0.04 m thick (X) × 0.80 m wide (Y) × 0.80 m tall (Z).
      Center at x=0.57, so the face toward the robot is at x=0.55 m.
    -->
    <model name="estop_wall">
      <static>true</static>
      <pose>0.57 0.0 0.40 0 0 0</pose>
      <link name="wall_link">
        <visual name="visual">
          <geometry>
            <box><size>0.04 0.80 0.80</size></box>
          </geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box><size>0.04 0.80 0.80</size></box>
          </geometry>
        </collision>
      </link>
    </model>

    <!--
      Emergency stop button — wall-mounted, horizontal axis.

      Orientation: rpy="0 -1.5708 0" rotates the model -90° around Y so that the
      local +Z axis (default cylinder/joint axis) maps to world -X.
      This means the button cap points TOWARD the robot (world -X direction)
      and the arm presses it by moving in world +X (into the wall).

      Layout in world coordinates (model frame at x=0.55, z=0.35):
        housing center  → (0.525,  0,  0.35)   [protrudes 5 cm from wall face]
        cap center      → (0.485,  0,  0.35)   at rest
        cap front face  → (0.470,  0,  0.35)   ← robot presses here

      Joint limits  : [-0.025, 0.0] m   (25 mm travel)
      Spring        : 500 N/m  →  ~12.5 N to fully depress
      Damping       : 10 N·s/m

      The housing is anchored to the world via a fixed joint so it never drifts
      even when the arm applies lateral loads.
    -->
    <model name="emergency_stop_button">
      <pose>0.55 0.0 0.35 0 -1.5708 0</pose>

      <!-- Yellow cylindrical housing -->
      <link name="button_housing">
        <!-- center = l/2 = 0.05/2 = 0.025 m from model frame -->
        <pose>0 0 0.025 0 0 0</pose>
        <inertial>
          <mass>2.0</mass>
          <!-- cylinder r=0.03 m, l=0.05 m: Ixx=Iyy=m/12*(3r²+l²), Izz=m*r²/2 -->
          <inertia>
            <ixx>0.000867</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.000867</iyy><iyz>0</iyz>
            <izz>0.000900</izz>
          </inertia>
        </inertial>
        <visual name="housing_visual">
          <geometry>
            <cylinder><radius>0.03</radius><length>0.05</length></cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.78 0.0 1</ambient>
            <diffuse>0.95 0.78 0.0 1</diffuse>
            <specular>0.2 0.2 0.1 1</specular>
          </material>
        </visual>
        <collision name="housing_collision">
          <geometry>
            <cylinder><radius>0.03</radius><length>0.05</length></cylinder>
          </geometry>
          <surface>
            <friction>
              <ode><mu>100</mu><mu2>100</mu2></ode>
            </friction>
            <contact>
              <ode><kp>1e6</kp><kd>100</kd></ode>
            </contact>
          </surface>
        </collision>
      </link>

      <!-- Red pressable mushroom cap -->
      <link name="button_cap">
        <!-- At rest: housing_front(0.05) + cap_half(0.015) = 0.065 → world x = 0.55 - 0.065 = 0.485 m -->
        <pose>0 0 0.065 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <!-- cylinder r=0.028 m, l=0.030 m: Ixx=Iyy=m/12*(3r²+l²), Izz=m*r²/2 -->
          <inertia>
            <ixx>0.0000217</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0000217</iyy><iyz>0</iyz>
            <izz>0.0000314</izz>
          </inertia>
        </inertial>
        <visual name="cap_visual">
          <geometry>
            <cylinder><radius>0.028</radius><length>0.030</length></cylinder>
          </geometry>
          <material>
            <ambient>0.85 0.05 0.05 1</ambient>
            <diffuse>0.85 0.05 0.05 1</diffuse>
            <specular>0.4 0.2 0.2 1</specular>
          </material>
        </visual>
        <collision name="cap_collision">
          <geometry>
            <cylinder><radius>0.028</radius><length>0.030</length></cylinder>
          </geometry>
          <surface>
            <friction>
              <ode><mu>0.8</mu><mu2>0.8</mu2></ode>
            </friction>
            <contact>
              <ode><kp>1e5</kp><kd>50</kd></ode>
            </contact>
          </surface>
        </collision>
      </link>

      <!--
        Fixed joint: anchors housing to world so it cannot drift.
        Required because the model is non-static (needed for the prismatic joint physics).
      -->
      <joint name="housing_world_fix" type="fixed">
        <parent>world</parent>
        <child>button_housing</child>
      </joint>

      <!--
        Prismatic joint: housing → cap, axis along local Z (= world -X).
        Positive displacement = cap moving toward robot (away from wall).
        When pressed: joint goes 0 → -0.025 m (cap retracts into housing).
        Spring pushes cap back out (toward robot) when released.
      -->
      <joint name="button_press_joint" type="prismatic">
        <parent>button_housing</parent>
        <child>button_cap</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-0.025</lower>
            <upper>0.0</upper>
            <effort>50</effort>
            <velocity>0.5</velocity>
          </limit>
          <dynamics>
            <spring_reference>0.0</spring_reference>
            <spring_stiffness>500.0</spring_stiffness>
            <damping>10.0</damping>
          </dynamics>
        </axis>
        <physics>
          <ode>
            <implicit_spring_damper>true</implicit_spring_damper>
          </ode>
        </physics>
      </joint>

    </model>

  </world>
</sdf>
